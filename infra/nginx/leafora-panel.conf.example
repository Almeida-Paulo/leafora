server {
    listen 80;
    listen [::]:80;

    server_name YOUR_ADMIN_DOMAIN;

    root /var/www/leafora/apps/admin;
    index index.html;

    access_log /var/log/nginx/leafora-panel.access.log;
    error_log /var/log/nginx/leafora-panel.error.log warn;

    auth_basic "Leafora Panel";
    auth_basic_user_file /etc/nginx/.leafora-panel.htpasswd;

    location /api/ {
        proxy_pass http://127.0.0.1:18473/api/;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ~* ^/assets/.*\.(js|css)$ {
        try_files $uri =404;
        access_log off;
        expires -1;
        add_header Cache-Control "no-cache";
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    add_header X-Robots-Tag "noindex, nofollow, noarchive" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), camera=(), microphone=()" always;
}
